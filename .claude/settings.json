{
  "projectName": "Dynatrace Terraform Migration Tools",
  "projectType": "python",
  "version": "0.4.0",
  "description": "Standalone tools for Dynatrace configuration migration between tenants using Terraform-compatible workflows",

  "repository": {
    "owner": "timstewart-dynatrace",
    "name": "dt-terraform-example",
    "url": "https://github.com/timstewart-dynatrace/dt-terraform-example"
  },

  "standards": {
    "semanticVersioning": true,
    "branchingStrategy": "feature/fix",
    "requiresDocumentation": true,
    "requiresTests": true,
    "requiresChangeLog": true
  },

  "minimumCodeQuality": {
    "typeHints": true,
    "docstrings": true,
    "linting": "ruff",
    "formatter": "ruff format",
    "typeChecker": "mypy",
    "testing": "pytest",
    "coverage": 80
  },

  "pythonEnvironment": {
    "version": "3.8+",
    "packageManager": "pip",
    "virtualEnv": "venv",
    "requirementsFile": "requirements.txt"
  },

  "customInstructions": "When a task is complete: 1. Log design decisions to DECISIONS.md. 2. Update active phase file with next step. 3. Do automatically before summarizing."
}
