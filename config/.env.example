# Dynatrace Terraform Configuration Migration - Environment Configuration
#
# Copy this file to .env and update with your actual values
#
# SECURITY: Never commit the .env file to version control!
# The .gitignore already excludes .env files.
#

# Source Tenant Configuration
# =========================
# The source tenant that will be migrated FROM
SOURCE_TENANT_URL="https://your-source-tenant-id.live.dynatrace.com"
SOURCE_TENANT_TOKEN="dt0c01.xxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Target Tenant Configuration
# =========================
# The target tenant that will be migrated TO
TARGET_TENANT_URL="https://your-target-tenant-id.live.dynatrace.com"
TARGET_TENANT_TOKEN="dt0c01.xxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional Configuration Directory
# ================================
# Location to store downloaded configurations
# Default: config
# CONFIG_DIR="config"

# GitHub Configuration (for pipeline push/pull)
# =============================================
# GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# GITHUB_REPO="CORP/dt-configs"
# GITHUB_BRANCH="main"
# GITHUB_PATH="exported"

# Pipeline Configuration File (optional, defaults to config/pipeline.yaml)
# PIPELINE_CONFIG="config/pipeline.yaml"

# Optional Terraform Debug Logging
# ================================
# Set to DEBUG, TRACE, INFO, WARN, or ERROR for verbose Terraform output
# TF_LOG="DEBUG"
